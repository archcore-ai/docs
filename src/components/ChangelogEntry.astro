---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'changelog'>;
	standalone?: boolean;
}

const { entry, standalone = false } = Astro.props;
const { version, date, title } = entry.data;
const href = `/changelog/${entry.id}/`;

const formattedDate = date.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});
---

<article class="changelog-entry">
	<header class="changelog-header">
		<span class="changelog-version">{version}</span>
		<time datetime={date.toISOString()} class="changelog-date">{formattedDate}</time>
	</header>
	{standalone ? (
		<div class="changelog-body">
			<slot />
		</div>
	) : (
		<>
			<h2 class="changelog-title">
				<a href={href}>{title}</a>
			</h2>
			{entry.data.description && (
				<p class="changelog-description">{entry.data.description}</p>
			)}
			<a href={href} class="changelog-read-more">Read more &rarr;</a>
		</>
	)}
</article>
